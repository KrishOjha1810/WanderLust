# Copy to .env and fill in your own values. Never commit the real .env.

# MongoDB connection string (Atlas or local)
ATLASDB_URL=mongodb://localhost:27017/wanderlust

# Express session secret (use a long random string)
SECRET=change-me-to-a-long-random-string

# Cloudinary credentials (image uploads)
CLOUD_NAME=your_cloudinary_cloud_name
CLOUD_API_KEY=your_cloudinary_api_key
CLOUD_API_SECRET=your_cloudinary_api_secret

# Mapbox public access token (maps)
MAP_TOKEN=your_mapbox_token
